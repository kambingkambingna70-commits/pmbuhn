# Copy file ini ke .env dan isi dengan nilai asli kamu
# File .env JANGAN di-commit ke GitHub!

# Database (freesqldatabase.com)
MYSQLHOST=sql12.freesqldatabase.com
MYSQLPORT=3306
MYSQLDATABASE=your_database_name
MYSQLUSER=your_db_username
MYSQLPASSWORD=your_db_password

# SMTP - Brevo (regenerate di https://app.brevo.com/settings/keys/smtp)
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USERNAME=your_brevo_smtp_username
MAIL_PASSWORD=your_brevo_smtp_key

# JWT Secret - generate random string panjang
# contoh: openssl rand -hex 64
JWT_SECRET=your_super_secret_jwt_key_min_32_chars

# Gemini AI (regenerate di https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key

# Resend API (opsional, untuk cloud deployment)
RESEND_API_KEY=

# BRIVA Payment Gateway
BRIVA_API_KEY=your_briva_api_key
BRIVA_API_SECRET=your_briva_api_secret
BRIVA_CLIENT_ID=your_briva_client_id

# App
PORT=9500
FRONTEND_URL=http://localhost:9500
